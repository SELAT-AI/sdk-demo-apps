# Arc mainnet (chainId 5042). Payments draw from the depositor EOA's Circle
# Gateway balance on Arc.
SELAT_CHAIN=arc
SELAT_ROUTER_URL=https://router.selat.ai

# Private key of the EOA that is the Arc Gateway depositor wallet. Signs every
# Gateway-batched payment in-process (no Circle CLI, no signing service).
#
# SECRET — never commit this. Set it in `.env.local` for local dev (gitignored)
# and in your Vercel project's Environment Variables for production.
X402_CLIENT_PRIVATE_KEY=
