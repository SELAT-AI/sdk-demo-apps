SELAT_CHAIN=base
SELAT_ROUTER_URL=https://router.selat.ai

# Fast local demo path:
X402_CLIENT_PRIVATE_KEY=

# Circle Agent Wallet path (LOCAL ONLY — signs via the local `circle` CLI,
# which is not available on Vercel / serverless):
SELAT_SIGNER_ADDRESS=

# Circle Agent Wallet path on Vercel / serverless:
# Point SELAT_SIGNER_API_URL at a hosted signing service (where the Circle CLI
# and Agent Wallet credentials live) that accepts `POST { address, typedData }`
# and returns `{ signature }`. Requires SELAT_SIGNER_ADDRESS to be set as well.
SELAT_SIGNER_API_URL=
# Optional bearer token sent to the remote signer as `Authorization: Bearer ...`
SELAT_SIGNER_API_TOKEN=
