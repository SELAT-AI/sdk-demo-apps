SELAT_CHAIN=base
SELAT_ROUTER_URL=https://router.selat.ai

# Circle developer-controlled wallet (recommended — works locally and on Vercel /
# serverless). Signing is a pure HTTPS call to Circle's API; signer material never
# reaches the browser. Set all four:
#   - SELAT_SIGNER_ADDRESS: the wallet's on-chain address (the SCA address for
#     Gateway-batched flows). Used as the signer address and for Gateway activity.
#   - CIRCLE_API_KEY:        your Circle API key.
#   - CIRCLE_ENTITY_SECRET:  your 32-byte hex entity secret (the SDK encrypts it
#     into a fresh, single-use ciphertext on every request).
#   - CIRCLE_WALLET_ID:      the developer-controlled wallet id that signs.
SELAT_SIGNER_ADDRESS=
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
CIRCLE_WALLET_ID=

# Fast local demo path (in-process private key; not the Circle custody model):
X402_CLIENT_PRIVATE_KEY=

# Admin area (/admin) — gates Gateway funding behind a password login.
#   - ADMIN_PASSWORD:        set this to enable the admin login.
#   - ADMIN_SESSION_SECRET:  HMAC key for the session cookie. Optional; defaults
#     to ADMIN_PASSWORD. Set a distinct random value in production.
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Eco gasless Gateway deposits (https://docs.eco.com/addresses/gateway-fast-deposits).
# Optional dApp id sent for attribution. Deposits use the same Circle wallet
# above (which must be an EOA) and the SELAT_CHAIN source chain (base, optimism,
# or arbitrum).
ECO_DAPP_ID=
