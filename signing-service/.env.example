# Port the service listens on (default 8787)
PORT=8787

# Shared secret the demo sends as `Authorization: Bearer <token>`.
# Must match the demo app's SELAT_SIGNER_API_TOKEN. Required.
SIGNER_API_TOKEN=

# The Circle Agent Wallet address this service signs for. Must match the demo
# app's SELAT_SIGNER_ADDRESS. Required.
CIRCLE_SIGNER_ADDRESS=

# Chain the wallet signs on (default base).
CIRCLE_SIGNER_CHAIN=base

# Max request body size in bytes (default 1 MiB).
MAX_BODY_BYTES=1048576
